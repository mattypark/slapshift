# Swift / Xcode
.build/
DerivedData/
*.xcuserstate
xcuserdata/
*.swp
build/
*.xcarchive

# Node / Next.js
node_modules/
.next/
out/
.vercel/

# Env files — per CLAUDE.md, never committed, never read
.env
.env.*
!.env.example

# macOS
.DS_Store

# Logs
*.log

# Notarization artifacts (build/ is also covered above)
*.dmg
*.zip
# Exception: DMGs staged for Vercel CDN. Sparkle auto-update fetches these
# from slapshift.app/dl/, so they MUST be tracked + pushed for prod 404s.
!web/public/dl/*.dmg
