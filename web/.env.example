# SlapShift web — environment template
#
# Copy to .env.local and fill in. NEVER commit .env.local.
# All Supabase + Stripe + Resend secrets live here.

# --- Public site URL ---
# Used in Stripe success_url, cancel_url, and the deep-link in the license email.
# In production this is your Vercel domain, e.g. https://slapshift.app
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# --- Supabase ---
# Project URL: https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_URL=
# Service role key — SERVER ONLY. Never expose to the client.
# This bypasses Row Level Security. Required for inserting licenses from the webhook.
SUPABASE_SERVICE_ROLE_KEY=

# --- Stripe ---
# Test keys start with sk_test_ / pk_test_. Switch to sk_live_ / pk_live_ for production.
STRIPE_SECRET_KEY=
# Webhook signing secret — required to verify webhook events came from Stripe.
# Get from: Stripe Dashboard → Developers → Webhooks → (your endpoint) → Signing secret
STRIPE_WEBHOOK_SECRET=
# Price ID for the $9.99 one-time SlapShift license. Looks like price_1...
STRIPE_PRICE_ID=

# --- Resend (email) ---
# API key from resend.com → API Keys.
RESEND_API_KEY=
# "From" address. Must be a verified sender in Resend (e.g. licenses@slapshift.app)
RESEND_FROM_EMAIL=licenses@slapshift.app

# --- License key hashing ---
# HMAC secret used to derive key_hash from the plaintext license key.
# Generate once with: openssl rand -hex 32
# Rotating this invalidates EVERY existing license. Treat it like a database password.
LICENSE_HMAC_SECRET=

# --- DMG download URL (used by Landing.tsx download button) ---
# Once you upload the notarized DMG to R2/Vercel Blob/S3, paste the public URL here.
NEXT_PUBLIC_DMG_URL=
